@page "/login"
@using MauiTimesheet.Components.Layout

@layout AuthLayout

@inject NavigationManager NavigationManager
@inject AuthService AuthService

<SectionContent SectionName="title">Login</SectionContent>
<SectionContent SectionName="loginRegisterText">
    <p>Don't have an account?</p>
</SectionContent>
<SectionContent SectionName="loginRegisterLink">
    <NavLink href="register" class="mt-3 text-blue-600">Create a new Account</NavLink>
</SectionContent>

<EditForm Model="_model" OnValidSubmit="LoginAsync">
    <DataAnnotationsValidator />
    <div class="mb-4">
        <label class="app-label">Username</label>
        <InputText @bind-Value="_model.Username" placeholder="Enter username" 
        class="app-input"/>
        <ValidationMessage For="()=> _model.Username" class="text-red-500 mt-2 text-xs"/>
    </div>
    <div class="mb-4">
        <label class="app-label">Password</label>
        <InputText type="password" @bind-Value="_model.Password" placeholder="Enter password" 
        class="app-input"/>
        <ValidationMessage For="()=> _model.Password" class="text-red-500 mt-2 text-xs"/>
    </div>
    <button type="submit" class="app-btn-full">Login</button>
</EditForm>

@code {
    private LoginModel _model = new();

    protected override void OnInitialized()
    {
        CommonState.HideLoader();
    }

    private async Task LoginAsync()
    {
        CommonState.ShowLoader();
        var isSucces = await AuthService.LoginAsync(_model);
        if (isSucces)
        {
            NavigationManager.NavigateTo("dashboard", replace: true);
        }
        CommonState.HideLoader();
    }
}
