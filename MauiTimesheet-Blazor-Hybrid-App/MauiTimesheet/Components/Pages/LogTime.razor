@page "/log-time"

@inject TimeLogService TimeLogService

<div class="flex h-full w-full flex-col gap-5 p-3">
    <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold text-gray-800">Log Time</h1>
        <button type="button" class="app-btn" @onclick="() => _showAddModal = true">+ Log Time</button>
    </div>
    <div class="flex flex-1 flex-col gap-3 overflow-y-auto">
        <div class="flex items-center gap-3 rounded-lg bg-white p-3 text-center shadow-lg">
            <button type="button" class="" @onclick="@(() => SelectedDate = SelectedDate.AddDays(-1).Date)">
                <img src="images/left.svg" class="" />
            </button>

            <div class="flex flex-1 flex-col items-center">
                <input type="date" @bind="SelectedDate" style="visibility: hidden" class="h-0 w-0" id="date-selection-input" />
                <span class="text-xs text-gray-500">@SelectedDate.ToString("ddd, MMM yyyy")</span>
                <h4 class="text-md flex items-center gap-2 font-bold" onclick="document.getElementById('date-selection-input').click()">
                    <img src="images/calendar.svg" class="h-4 w-4" />
                    <span>@SelectedDate.ToString("dd-MM-yyyy")</span>
                </h4>
                <button type="button" class="mt-3 text-xs text-blue-400" @onclick="@(() => SelectedDate = DateTime.Now.Date)">Go to Today</button>
            </div>

            <button type="button" class="" @onclick="@(() => SelectedDate = SelectedDate.AddDays(1).Date)">
                <img src="images/right.svg" class="" />
            </button>
        </div>
        <div class="overflow-y-auto rounded-lg bg-white p-3 shadow-lg @(TimeLogService.Entries.Count > 0 ? "flex-1" : "")">
            <h4 class="text-md mb-4 font-medium text-gray-700">Entries for @SelectedDate.ToString("ddd, MMMM dd, yyyy")</h4>
            @if (TimeLogService.Entries.Count == 0)
            {
                <div class="mx-auto my-6 flex w-full flex-col items-center gap-4 p-6">
                    <img src="images/clock.svg" />
                    <label class="text-gray-500">No time logged for this date</label>
                </div>
            }
            else
            {
                <TimeLogDisplayList Entries="TimeLogService.Entries"
                                    ShowTotal
                                    ShowDeleteOption
                                    OnDelete="HandleTaskDeleteAsync" />
            }
        </div>
    </div>
</div>

@if (_showAddModal)
{
    <AddTimeLogForm Date="SelectedDate"
                    OnClose="() => _showAddModal = false"
                    OnAfterSave="HandleTimeLogAdded" />
}

@code {
    private bool _showAddModal = false;

    private DateTime _selectedDate = DateTime.Now.Date;
    private DateTime SelectedDate
    {
        get => _selectedDate;
        set
        {
            if (_selectedDate != value)
            {
                _selectedDate = value;
                _ = HandleDateChanged();
            }
        }
    }

    protected override async Task OnInitializedAsync() => await FetchTimeLogsAsync();

    private async Task HandleDateChanged() => await FetchTimeLogsAsync();

    private async Task FetchTimeLogsAsync()
    {
        CommonState.ShowLoader();
        await TimeLogService.LoadTimeLogsAsync(SelectedDate);
        await InvokeAsync(StateHasChanged);
        CommonState.HideLoader();
    }


    private void HandleTimeLogAdded()
    {
        _showAddModal = false;
        StateHasChanged();
    }

    private async Task HandleTaskDeleteAsync(int timeLogId)
    {
        if (await MauiInterop.ConfirmAsync("Do you really want to delete this entry?", "Confimr Deletion?"))
        {
            CommonState.ShowLoader();
            if (await TimeLogService.DeleteEntryAsync(timeLogId))
            {
                await FetchTimeLogsAsync();
            }
            CommonState.HideLoader();
        }
    }
}
