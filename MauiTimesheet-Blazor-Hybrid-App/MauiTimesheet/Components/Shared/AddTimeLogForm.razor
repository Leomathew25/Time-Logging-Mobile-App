
@inject ProjectsService ProjectsService
@inject TimeLogService TimeLogService

<div class="fixed inset-0 z-40 flex items-center justify-center bg-black bg-opacity-50 p-8">
    <div class="w-full rounded-lg bg-white p-6 shadow-lg">
        <h2 class="mb-5 text-xl font-semibold text-gray-600">Add Time</h2>
        <EditForm Model="_entry" OnValidSubmit="AddTimeLogAsync">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label class="app-label">Project</label>
                <InputSelect @bind-Value="_entry.ProjectId" class="app-input">
                    @foreach (var p in ProjectsService.Projects)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => _entry.ProjectId" class="app-validation-msg" />
            </div>
            <div class="mb-3 flex-1">
                <label class="app-label">Date</label>
                <InputDate @bind-Value="_entry.Date" class="app-input" />
                <ValidationMessage For="() => _entry.Date" class="app-validation-msg" />
            </div>
            <div class="mb-3">
                <label class="app-label">Hours</label>
                <InputNumber @bind-Value="_entry.Hours" class="app-input" min="0.25" />
                <ValidationMessage For="() => _entry.Hours" class="app-validation-msg" />
            </div>
                       
            <div class="mb-3">
                <label class="app-label">Task</label>
                <InputText @bind-Value="_entry.Task" class="app-input" />
                <ValidationMessage For="() => _entry.Task" class="app-validation-msg" />
            </div>
            
            <div class="mb-3">
                <label class="app-label">Description (Optional)</label>
                <InputTextArea @bind-Value="_entry.Description" placeholder="Enter project description" rows="3" 
                class="app-input" />
                <ValidationMessage For="() => _entry.Description" class="app-validation-msg" />
            </div>           
            <div class="mt-3 flex gap-3">
                <button type="button" @onclick="() => OnClose.InvokeAsync()" class="app-btn border border-gray-700 bg-white text-gray-700">Cancel</button>
                <button type="submit" class="app-btn-full">Add Time</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public DateTime Date { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnAfterSave { get; set; }

    private TimeLogEntryModel _entry = new();

    protected override async Task OnInitializedAsync()
    {
        CommonState.ShowLoader();
        if(ProjectsService.Projects.Count == 0)
            await ProjectsService.LoadProjectsAsync();
        CommonState.HideLoader();
    }

    protected override void OnParametersSet()
    {
        _entry.Date = Date;
    }

    private async Task AddTimeLogAsync()
    {
        CommonState.ShowLoader();
        var isSuccess = await TimeLogService.SaveEntryAsync(_entry);
        CommonState.HideLoader();
        if (!isSuccess)
            return;

        await OnAfterSave.InvokeAsync();
    }
}
